NOTION_API_KEY=
# Use ONE of: database (table) OR parent page for sub-pages
# 32 hex chars or hyphenated UUID from the database URL
NOTION_DB_ID=
# If the URL opens a normal page (not a table database), put that page id here instead
NOTION_PAGE_ID=
# Title property name in your Notion database (often "Name" or "Title")
NOTION_TITLE_PROPERTY=Name
# Optional: select properties — only set if they exist with matching option names
NOTION_CATEGORY_PROPERTY=
NOTION_TYPE_PROPERTY=

# LLM: use Groq (OpenAI-compatible) OR OpenAI — not both required
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Optional override; default is https://api.groq.com/openai/v1
# GROQ_BASE_URL=

# If you prefer OpenAI instead, set OPENAI_API_KEY and leave GROQ_API_KEY empty
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# Daemon defaults
SHADOW_WORKSPACE=
SHADOW_DEBOUNCE_MS=8000
SHADOW_TICK_MS=45000
